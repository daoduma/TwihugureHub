# ─────────────────────────────────────────────────────────────────
# TWIHUGURE HUB — ENVIRONMENT VARIABLES TEMPLATE
# Stack: Next.js · Supabase (PostgreSQL) · Vercel · Groq AI
#
# HOW TO USE:
# 1. Copy this file and rename the copy to .env
# 2. Fill in every value marked REPLACE_THIS
# 3. Never commit your .env file to GitHub
# 4. This .env.example file is safe to commit — no real values here
# ─────────────────────────────────────────────────────────────────


# ── DATABASE (SUPABASE) ───────────────────────────────────────────
# Get both URLs from your Supabase project:
# → Open your project on supabase.com
# → Click the green "Connect" button at the top of the page

# Pooled — used by the running app on Vercel (port 6543, transaction mode)
# Connect button → Transaction mode tab
# If your password contains @ replace it with %40
DATABASE_URL="postgresql://postgres.REPLACE_THIS_PROJECT_REF:REPLACE_THIS_PASSWORD@aws-0-REPLACE_THIS_REGION.pooler.supabase.com:6543/postgres"

# Session pooler — used by Prisma to run migrations on Vercel (port 5432)
# IMPORTANT: This must also use the pooler host (aws-0-...) NOT the direct host (db....)
# because Vercel runs on IPv4 and the direct host only supports IPv6
# Connect button → Session mode tab
DIRECT_URL="postgresql://postgres.REPLACE_THIS_PROJECT_REF:REPLACE_THIS_PASSWORD@aws-0-REPLACE_THIS_REGION.pooler.supabase.com:5432/postgres"


# ── AUTH ──────────────────────────────────────────────────────────

# Random secret for signing session tokens
# Generate by running this in your terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or get one from: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=REPLACE_THIS_WITH_GENERATED_SECRET

# Your app URL
# Local development : http://localhost:3000
# After Vercel deploy: https://your-project-name.vercel.app
# After custom domain: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000


# ── ENCRYPTION ────────────────────────────────────────────────────

# Encrypts your AI API key before storing it in the database
# MUST be exactly 32 characters — no more, no less
# You can make this up — verify the length with:
# node -e "console.log('YourChosenSecret'.length)"
ENCRYPTION_SECRET=REPLACE_THIS_MUST_BE_EXACTLY_32C


# ── AI / LLM (GROQ) ───────────────────────────────────────────────
# Get your free API key from: https://console.groq.com → API Keys
AI_PROVIDER=openai_compatible
AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=REPLACE_THIS_WITH_YOUR_GROQ_KEY
AI_BASE_URL=https://api.groq.com/openai/v1


# ── FILE UPLOADS (SUPABASE STORAGE) ──────────────────────────────
# Files are uploaded to a Supabase Storage bucket and served via CDN.
#
# NEXT_PUBLIC_SUPABASE_URL
#   Your project URL — found at: Supabase dashboard → Project Settings → API
#   e.g. https://xyzxyzxyz.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://REPLACE_THIS_PROJECT_REF.supabase.co
#
# SUPABASE_SERVICE_ROLE_KEY
#   The service role (secret) key — same page, "service_role" row.
#   KEEP THIS SECRET — it bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_THIS_SERVICE_ROLE_KEY
#
# SUPABASE_STORAGE_BUCKET
#   Name of the Storage bucket to upload files into.
#   Create it at: Supabase dashboard → Storage → New bucket
#   Make it PUBLIC so uploaded files are accessible via CDN URL.
#   Default value if this variable is omitted: "uploads"
SUPABASE_STORAGE_BUCKET=uploads


# ─────────────────────────────────────────────────────────────────
# VERCEL ENVIRONMENT VARIABLES CHECKLIST
# Add all of the above to: Vercel → Project → Settings → Environment Variables
# Make sure Production is ticked for every variable
#
# The one value that changes between local and Vercel:
# Local  → NEXTAUTH_URL=http://localhost:3000
# Vercel → NEXTAUTH_URL=https://your-project-name.vercel.app
#
# Your two database URLs must BOTH use the pooler host:
# aws-0-REGION.pooler.supabase.com
# NOT the direct host: db.PROJECTREF.supabase.co
# (The direct host is IPv6 only — Vercel requires IPv4)
# ─────────────────────────────────────────────────────────────────
