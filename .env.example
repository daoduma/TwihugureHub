# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/twihugurehub

# ─── Auth (NextAuth) ──────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-secret-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# ─── Encryption (for API key storage in DB) ──────────────────────────────────
# Must be exactly 32 characters
ENCRYPTION_SECRET=32-character-secret-here-pad-ok!

# ─── LLM Fallback (used if no DB config exists — local dev) ──────────────────
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-20250514
AI_API_KEY=your-api-key-here

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_PROVIDER=local           # or 's3'
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
