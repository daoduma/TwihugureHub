# ─── TwihugureHub — Environment Variables ─────────────────────────────────────
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to source control.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma format)
# Example for local dev:  postgresql://postgres:password@localhost:5432/twihugure
# Example for Supabase:   postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/twihugure"

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace_with_a_secure_random_string_at_least_32_chars"

# The canonical URL of your app (no trailing slash)
# Development:  http://localhost:3000
# Production:   https://twihugure.rw
NEXTAUTH_URL="http://localhost:3000"

# ─── App (optional) ────────────────────────────────────────────────────────────
# Node environment (next dev sets this automatically)
NODE_ENV="development"
