# ─────────────────────────────────────────────────────────────────
# TWIHUGURE HUB — ENVIRONMENT VARIABLES TEMPLATE
# Place this file at: twihugure-final/.env.example
#
# HOW TO USE:
# 1. Copy this file and rename the copy to .env
# 2. Fill in every value marked with REPLACE_THIS
# 3. Never commit your .env file to GitHub
# 4. This .env.example file is safe to commit — it has no real values
# ─────────────────────────────────────────────────────────────────


# ── DATABASE ──────────────────────────────────────────────────────
# Both URLs come from your Supabase project.
# Go to your Supabase project → click the green "Connect" button at the top.

# Pooled connection — used by the running app (Vercel serverless)
# Get this from: Connect button → Transaction mode tab
# Port is 6543
# If your password contains @ replace it with %40
DATABASE_URL="postgres://postgres.REPLACE_THIS_PROJECT_REF:REPLACE_THIS_PASSWORD@aws-0-REPLACE_THIS_REGION.pooler.supabase.com:6543/postgres"

# Direct connection — used only by Prisma when running migrations
# Get this from: Connect button → Direct connection tab
# Port is 5432
DIRECT_URL="postgresql://postgres.REPLACE_THIS_PROJECT_REF:REPLACE_THIS_PASSWORD@db.REPLACE_THIS_PROJECT_REF.supabase.co:5432/postgres"


# ── AUTH ──────────────────────────────────────────────────────────

# Random secret for signing and encrypting session tokens
# Generate on Windows with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Or get one instantly from:
#   https://generate-secret.vercel.app/32
NEXTAUTH_SECRET=REPLACE_THIS_WITH_GENERATED_SECRET

# Your app's URL
# Local development:  http://localhost:3000
# After Vercel deploy: https://your-project-name.vercel.app
# After custom domain: https://yourdomain.com
NEXTAUTH_URL=http://localhost:3000


# ── ENCRYPTION ────────────────────────────────────────────────────

# Used to encrypt your AI API key before it is stored in the database
# Rules:
#   - Must be EXACTLY 32 characters — not 31, not 33
#   - You can make this up yourself
#   - Check the length on Windows with:
#     node -e "console.log('YourChosenSecret'.length)"
ENCRYPTION_SECRET=REPLACE_THIS_MUST_BE_EXACTLY_32C


# ── AI / LLM ──────────────────────────────────────────────────────
# These control which AI provider is used for quiz translation.
# The app supports: anthropic | openai | google | mistral | openai_compatible
#
# ── Option 1: Groq (recommended — fast and free tier available)
# Get your API key from: https://console.groq.com → API Keys
AI_PROVIDER=openai_compatible
AI_MODEL=llama-3.3-70b-versatile
AI_API_KEY=REPLACE_THIS_WITH_YOUR_GROQ_KEY
AI_BASE_URL=https://api.groq.com/openai/v1
#
# ── Option 2: Anthropic Claude
# Get your API key from: https://console.anthropic.com → API Keys
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-20250514
# AI_API_KEY=REPLACE_THIS_WITH_YOUR_ANTHROPIC_KEY
# AI_BASE_URL=
#
# ── Option 3: OpenAI
# Get your API key from: https://platform.openai.com → API Keys
# AI_PROVIDER=openai
# AI_MODEL=gpt-4o
# AI_API_KEY=REPLACE_THIS_WITH_YOUR_OPENAI_KEY
# AI_BASE_URL=
#
# ── Option 4: Google Gemini
# Get your API key from: https://aistudio.google.com → Get API Key
# AI_PROVIDER=google
# AI_MODEL=gemini-1.5-flash
# AI_API_KEY=REPLACE_THIS_WITH_YOUR_GOOGLE_KEY
# AI_BASE_URL=
#
# ── Option 5: Mistral
# Get your API key from: https://console.mistral.ai → API Keys
# AI_PROVIDER=mistral
# AI_MODEL=mistral-small-latest
# AI_API_KEY=REPLACE_THIS_WITH_YOUR_MISTRAL_KEY
# AI_BASE_URL=


# ── FILE UPLOADS ──────────────────────────────────────────────────

# Controls where uploaded files (course materials, images) are stored
# Options: local | s3 | firebase
# Use 'local' to start — files saved to /public/uploads on the server
UPLOAD_PROVIDER=local

# Only needed if UPLOAD_PROVIDER=s3
# Get these from AWS Console → IAM → Users → Your User → Security credentials
AWS_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Only needed if UPLOAD_PROVIDER=firebase
# Get these from Firebase Console → Project Settings → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK — only needed if UPLOAD_PROVIDER=firebase
# Get these from Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=


# ── REDIS (OPTIONAL) ──────────────────────────────────────────────
# Currently unused but reserved for future session store / queue
# Leave blank unless you set up Redis
REDIS_URL=


# ─────────────────────────────────────────────────────────────────
# CHECKLIST BEFORE GOING LIVE ON VERCEL
# ─────────────────────────────────────────────────────────────────
# [ ] DATABASE_URL     — pooled Supabase URL (port 6543)
# [ ] DIRECT_URL       — direct Supabase URL (port 5432)
# [ ] NEXTAUTH_SECRET  — generated random string
# [ ] NEXTAUTH_URL     — set to your real Vercel/custom domain URL
# [ ] ENCRYPTION_SECRET — exactly 32 characters
# [ ] AI_PROVIDER      — one of the options above
# [ ] AI_MODEL         — matching model for your chosen provider
# [ ] AI_API_KEY       — real key from your AI provider dashboard
# [ ] AI_BASE_URL      — only needed for openai_compatible providers like Groq
# [ ] UPLOAD_PROVIDER  — start with 'local'
# ─────────────────────────────────────────────────────────────────